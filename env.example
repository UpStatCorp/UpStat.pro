# Основные настройки приложения
SECRET_KEY=your_secret_key_here_change_me
DEBUG=true
ENVIRONMENT=development

# База данных
# PostgreSQL настройки (для Docker используйте переменные ниже)
POSTGRES_USER=saas_user
POSTGRES_PASSWORD=saas_password_change_me
POSTGRES_DB=saas
DATABASE_PORT=5432

# URL базы данных
# Для Docker (автоматически формируется из переменных выше):
# DATABASE_URL=postgresql://saas_user:saas_password@postgres:5432/saas
# Для локального запуска без Docker:
DATABASE_URL=postgresql://saas_user:saas_password@localhost:5432/saas
# Для разработки с SQLite (не рекомендуется для production):
# DATABASE_URL=sqlite:///app.db

# Zoom API (обязательно для создания встреч) - Server-to-Server OAuth
ZOOM_CLIENT_ID=dT1mgFO_RymdgLVi9DGrQ
ZOOM_CLIENT_SECRET=TZAgY3fsGOgaAn8F68V71xvmlArq4D24
ZOOM_ACCOUNT_ID=kpPiSq1sQYCziRLtoXgMEw

# Zoom Meeting SDK (обязательно для подключения агента)
ZOOM_SDK_KEY=your_zoom_sdk_key
ZOOM_SDK_SECRET=your_zoom_sdk_secret

# OpenAI API (обязательно для GPT-4o)
OPENAI_API_KEY=sk-proj-D72HvflG1FnNFBji7DUUbICHmXpoLZJ0dqcu4HQW52LbRLMD0Bc9ItJfCscGLPRRtO3A_jHYzST3BlbkFJXjbsxNW22izrgqDcqC727XtOy1R56B402grqQqm6kNpN4

# ElevenLabs API (обязательно для TTS)
ELEVENLABS_API_KEY=sk_f703f10afe4b15a257fb112d00e44ce64c75ebb27baabddc

# Deepgram API (опционально, альтернатива Whisper)
DEEPGRAM_API_KEY=464ebd235ae5442a361e69e730d40fd4ea7de0b1

# Настройки сервисов
BACKEND_PORT=8000
AI_AGENT_SERVICE_PORT=8001
DATABASE_PORT=5432
REDIS_PORT=6379

# Настройки безопасности
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
ALLOWED_HOSTS=localhost,127.0.0.1

# Логирование
LOG_LEVEL=INFO
LOG_FORMAT=json

# Настройки аудио
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
AUDIO_CHUNK_DURATION=0.5

# Настройки пайплайна
MAX_CONCURRENT_MEETINGS=10
RESPONSE_DELAY_THRESHOLD=2.0

# Настройки Zoom
ZOOM_DEFAULT_TIMEZONE=Europe/Moscow
ZOOM_DEFAULT_DURATION=60
ZOOM_MAX_DURATION=480

# Настройки ИИ
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=1000
OPENAI_TEMPERATURE=0.7
# Настройки GPT для голосового ассистента
GPT_MODEL=gpt-4o-mini
GPT_MAX_TOKENS=150
GPT_TEMPERATURE=0.7

# Настройки TTS (Text-to-Speech)
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
# Провайдер TTS для голосового ассистента (openai, elevenlabs)
TTS_PROVIDER=elevenlabs
# Настройки OpenAI TTS (если TTS_PROVIDER=openai)
TTS_MODEL=tts-1
TTS_VOICE=nova
OPENAI_TTS_SPEED=1.0

# Параметры стабильности голоса ElevenLabs (для постоянной тональности)
ELEVENLABS_STABILITY=0.75
ELEVENLABS_SIMILARITY_BOOST=0.8
ELEVENLABS_STYLE=0.0
ELEVENLABS_USE_SPEAKER_BOOST=true

# Настройки STT (Speech-to-Text)
DEEPGRAM_MODEL=nova-2
DEEPGRAM_LANGUAGE=ru-RU
WHISPER_MODEL=whisper-1
# Провайдер STT для голосового ассистента (whisper_openai, elevenlabs, whisper_local)
STT_PROVIDER=whisper_openai
# Для локального Whisper (если STT_PROVIDER=whisper_local)
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Google OAuth настройки
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=https://up-stat.com/auth/google/callback

# CRM интеграции
# AmoCRM OAuth настройки
# 1. Создайте интеграцию: AmoCRM → Настройки → Интеграции → Создать
# 2. Redirect URI в AmoCRM должен совпадать с AMOCRM_REDIRECT_URI ниже
AMOCRM_CLIENT_ID=your_amocrm_client_id
AMOCRM_CLIENT_SECRET=your_amocrm_client_secret
AMOCRM_REDIRECT_URI=https://up-stat.com/crm/oauth/callback

# Bitrix24 OAuth настройки (создать приложение на https://www.bitrix24.ru/apps/)
# Требуемые права: crm, telephony, user
BITRIX24_CLIENT_ID=your_bitrix24_client_id
BITRIX24_CLIENT_SECRET=your_bitrix24_client_secret
BITRIX24_REDIRECT_URI=https://up-stat.com/crm/oauth/callback

# Ключ шифрования для токенов CRM (генерируется автоматически если не задан)
CRM_ENCRYPTION_KEY=your_encryption_key_here_or_leave_empty_for_auto_generation

# Azure Voice Live API (для real-time голосовых тренировок)
AZURE_VOICE_LIVE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_VOICE_LIVE_API_KEY=your-api-key-here
AZURE_VOICE_LIVE_MODEL=gpt-4o-realtime-preview
AZURE_VOICE_LIVE_API_VERSION=2025-05-01-preview
AZURE_VOICE_LIVE_VOICE=en-US-Ava:DragonHDLatestNeural
AZURE_VOICE_LIVE_TRANSCRIPTION_MODEL=gpt-4o-transcribe
USE_AZURE_VOICE_LIVE=true
